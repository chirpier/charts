{
  "name": "@chirpier/embed",
  "version": "0.2.2",
  "description": "Framework-agnostic Chirpier hosted chart embed client",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "pack": "npm pack --dry-run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chirpier/charts.git"
  },
  "license": "MIT",
  "devDependencies": {
    "typescript": "^4.9.0"
  }
}
